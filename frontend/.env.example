# Optional. Leave unset in local dev - Vite proxies /api to the backend,
# so browser testing works at http://localhost:5173
#
# For a deployed web frontend, set this to your Railway backend origin.
# Do not put Gemini/API secrets in the frontend or Flutter app.
# VITE_API_URL=http://localhost:8000
# VITE_API_URL=https://your-backend.up.railway.app
