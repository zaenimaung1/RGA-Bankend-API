########################################
# 🧠 Application Settings
########################################
APP_NAME="Myanmar Proverbs AI Tutor"
ENVIRONMENT="development"

########################################
# 🌐 CORS / Frontend
########################################
# Browser origins allowed to call the backend.
# Flutter/mobile apps do not use browser CORS, but web frontends do.
# Add your deployed frontend origin here if you host one.
ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

########################################
# 🗄️ Database (MongoDB)
########################################
MONGODB_URI="mongodb://localhost:27017"
MONGODB_DB_NAME="mm_proverbs_ai"

########################################
# 🔐 Authentication (JWT)
########################################
JWT_SECRET_KEY="your-super-secret-key-change-this"
JWT_ALGORITHM="HS256"
JWT_EXPIRES_MINUTES=10080  # 7 days

########################################
# 🤖 LLM (Google Gemini)
# Add up to 3 keys separated by commas.
# When one key hits token/quota limits, the next key is used automatically.
# Keep these only on the backend/Railway. Do not ship them in Flutter.
########################################
GEMINI_API_KEYS="your-gemini-key-1,your-gemini-key-2,your-gemini-key-3"
GEMINI_MODEL="gemini-2.0-flash"
GEMINI_TIMEOUT_SECONDS=120
GEMINI_TEMPERATURE=0.0

########################################
# 📦 Vector Database (ChromaDB)
########################################
CHROMA_PERSIST_DIR="./chroma_data"
CHROMA_COLLECTION_NAME="proverbs"

########################################
# 🔎 RAG Settings
########################################
RAG_TOP_K=5
RAG_MIN_RELEVANCE_SCORE=0.5
RAG_MIN_LEXICAL_SIMILARITY=0.5
RAG_SEMANTIC_THRESHOLD=0.5

########################################
# 🎤 Speech-to-text (Whisper)
########################################
WHISPER_MODEL="base"
WHISPER_DEVICE="cpu"
WHISPER_COMPUTE_TYPE="int8"

########################################
# 👤 Admin Control
########################################
ADMIN_EMAIL="admin@example.com"
