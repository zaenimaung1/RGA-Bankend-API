# FastAPI
APP_NAME="Myanmar Proverbs AI Tutor"
ENVIRONMENT="local"
ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# MongoDB Atlas (or local Mongo)
MONGODB_URI="mongodb://localhost:27017"
MONGODB_DB_NAME="mm_proverbs_ai"

# JWT
JWT_SECRET_KEY="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"
JWT_ALGORITHM="HS256"
JWT_EXPIRES_MINUTES="10080"  # 7 days

# Gemini (generation only; embeddings use Chroma local model)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-flash-latest"

# ChromaDB
CHROMA_PERSIST_DIR="./chroma_data"
CHROMA_COLLECTION_NAME="proverbs"

# RAG
RAG_TOP_K="5"

# RBAC: email that gets admin role on register
ADMIN_EMAIL="admin@example.com"

